# Planning Poker - Environment Configuration
# Copy this file to .env and adjust values for your deployment.

# Production domain exposed by Pangolin (used for CORS and WebSocket origin check).
# Must match exactly what the browser sends in the Origin header.
# Example: ALLOWED_ORIGINS=https://poker.example.com
ALLOWED_ORIGINS=https://poker.example.com

# Port the Go backend listens on (internal to Docker network, never exposed to host)
BACKEND_PORT=8080

# Port exposed on the host — point Pangolin to this port
FRONTEND_PORT=3000
